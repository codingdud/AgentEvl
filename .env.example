# WARNING: DO NOT COMMIT SECRETS
# This file has been sanitized because a secret was accidentally committed.
# Add your own .env (with real keys) to .gitignore and never commit it.

# ── Provider selection ────────────────────────────────────────────────────────
# Set PROVIDER to one of: openrouter | gemini | openai
PROVIDER=gemini

# ── API keys (fill in the one matching your PROVIDER) ─────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
ELITEA_API_KEY=your_elitea_token_here

# ── Model override (optional — defaults shown below per provider) ─────────────
# openrouter default : openrouter/anthropic/claude-3-5-haiku
# gemini default     : gemini/models/gemini-2.5-flash
# openai default     : openai/gpt-4o-mini
# elitea default     : elitea/eu.anthropic.claude-sonnet-4-6
# MODEL=elitea/eu.anthropic.claude-sonnet-4-6

# ── Token pricing (per 1M tokens, used for cost display only) ─────────────────
# Set to your model's actual rates. Defaults: $1.00 / $1.00 per 1M.
# COST_INPUT=3.00
# COST_OUTPUT=15.00
